{
  "name": "@jacobwisniewski/openstack",
  "version": "0.1.0",
  "description": "Simple profile management for OpenCode configurations",
  "main": "dist/index.js",
  "bin": {
    "openstack": "dist/cli.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "lint": "oxlint --import-plugin --tsconfig tsconfig.json src/",
    "lint:fix": "oxlint --import-plugin --tsconfig tsconfig.json src/ --fix",
    "format": "oxfmt --write src/",
    "format:check": "oxfmt --check src/",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "opencode",
    "cli",
    "profile",
    "config",
    "ai"
  ],
  "author": "Jacob Wisniewski",
  "license": "MIT",
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "oxfmt": "^0.44.0",
    "oxlint": "^1.59.0",
    "typescript": "^5.0.0",
    "vitest": "^4.1.3"
  },
  "dependencies": {
    "commander": "^12.0.0"
  }
}
